{
  "name": "mystic-ui",
  "description": "Tailwind-first SolidJS UI components installable from the Mystic UI GitHub repo.",
  "version": "0.0.1",
  "workspaces": ["components/*", "packages/*", "templates/*", "website"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./components/tailwind/types/index.d.ts",
      "import": "./components/tailwind/src/index.ts"
    },
    "./tailwind": {
      "types": "./components/tailwind/types/index.d.ts",
      "import": "./components/tailwind/src/index.ts"
    }
  },
  "types": "./components/tailwind/types/index.d.ts",
  "files": [
    "components/tailwind/src/index.ts",
    "components/tailwind/src/lib/utils.ts",
    "components/tailwind/src/ui",
    "components/tailwind/types",
    "README.md",
    "LICENSE.md"
  ],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build:types": "bun scripts/build-types.mjs",
    "check": "bun run --filter '*' check",
    "check:types": "bun scripts/check-types.mjs",
    "check:github-package": "bun scripts/check-github-package.mjs",
    "githooks:install": "bun scripts/install-githooks.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "solid-js": "^1.9.3"
  },
  "dependencies": {
    "@tsparticles/engine": "^3.7.1",
    "@tsparticles/slim": "^3.7.1",
    "clsx": "^2.1.1",
    "motion": "^11.13.1",
    "rough-notation": "^0.5.1",
    "solid-icons": "1.1.0",
    "solid-motionone": "^1.0.2",
    "tailwind-merge": "^2.5.5"
  },
  "author": {
    "name": "Peter Ryszkiewicz",
    "url": "https://github.com/pRizz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pRizz/mystic-ui.git"
  },
  "homepage": "https://github.com/pRizz/mystic-ui",
  "bugs": {
    "url": "https://github.com/pRizz/mystic-ui/issues"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@mystic-ui/panda",
    "@mystic-ui/website",
    "@tsparticles/engine",
    "vite-panda"
  ]
}
