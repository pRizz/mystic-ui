{
  "name": "mystic-ui",
  "description": "Monorepo for Mystic UI",
  "version": "0.0.1",
  "workspaces": ["components/*", "packages/*", "templates/*", "website"],
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "check": "bun run --filter '*' check"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.3.3"
  },
  "author": {
    "name": "Peter Ryszkiewicz",
    "url": "https://github.com/pRizz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pRizz/mystic-ui.git"
  },
  "homepage": "https://github.com/pRizz/mystic-ui",
  "bugs": {
    "url": "https://github.com/pRizz/mystic-ui/issues"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@mystic-ui/panda",
    "@mystic-ui/website",
    "@tsparticles/engine",
    "vite-panda"
  ]
}
