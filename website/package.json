{
	"name": "@mystic-ui/website",
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "node ./node_modules/@pandacss/dev/bin.js codegen",
		"dev": "node ./node_modules/vinxi/bin/cli.mjs dev",
		"build": "node ./node_modules/@pandacss/dev/bin.js prepare && node ./node_modules/vinxi/bin/cli.mjs build",
		"build:pages": "node ./node_modules/@pandacss/dev/bin.js prepare && node ./node_modules/vinxi/bin/cli.mjs build && node ./scripts/finalize-pages.mjs",
		"start": "node ./node_modules/vinxi/bin/cli.mjs start",
		"gallery:screenshots": "node ./node_modules/playwright/cli.js test e2e/gallery-screenshots.spec.ts",
		"smoke:test": "node ./node_modules/playwright/cli.js test e2e/site-smoke.spec.ts",
		"smoke:test:pages": "PLAYWRIGHT_BASE_PATH=${PLAYWRIGHT_BASE_PATH:-/mystic-ui} node ./node_modules/playwright/cli.js test e2e/site-smoke.spec.ts",
		"version": "node ./node_modules/vinxi/bin/cli.mjs version",
		"format": "node ./node_modules/@biomejs/biome/bin/biome format src",
		"lint": "node ./node_modules/@biomejs/biome/bin/biome lint src",
		"check": "node ./node_modules/@biomejs/biome/bin/biome check src app.config.ts playwright.config.ts tailwind.config.js postcss.config.cjs e2e"
	},
	"dependencies": {
		"@ark-ui/solid": "^4.5.0",
		"@fontsource-variable/rubik": "^5.1.0",
		"@mystic-ui/panda": "workspace:*",
		"@solid-primitives/memo": "^1.3.10",
		"@solid-primitives/storage": "^4.2.1",
		"@solidjs/meta": "^0.29.4",
		"@solidjs/router": "^0.15.1",
		"@solidjs/start": "^1.0.10",
		"@tanstack/solid-store": "^0.5.7",
		"@vinxi/plugin-mdx": "^3.7.2",
		"motion": "^11.13.1",
		"remark-frontmatter": "^5.0.0",
		"solid-icons": "^1.1.0",
		"solid-js": "^1.9.3",
		"solid-motionone": "^1.0.2",
		"vinxi": "^0.4.3"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@content-collections/core": "^0.7.3",
		"@content-collections/solid-start": "^0.1.3",
		"@fastify/deepmerge": "^2.0.0",
		"@mystic-ui/registry": "workspace:*",
		"@pandacss/dev": "^0.47.1",
		"@park-ui/panda-preset": "^0.42.0",
		"@playwright/test": "^1.58.2",
		"autoprefixer": "^10.4.27",
		"postcss": "^8.5.8",
		"rehype-slug": "^6.0.0",
		"remark-code-extra": "^1.0.1",
		"remark-gfm": "^4.0.0",
		"shiki": "^1.22.2",
		"tailwindcss": "^3.4.19",
		"ts-deepmerge": "^7.0.1",
		"unist-util-visit": "^5.0.0",
		"vite-tsconfig-paths": "^5.1.2"
	}
}
