{
	"name": "@mystic-ui/cli",
	"version": "0.0.0-1",
	"description": "A CLI for adding beautiful mystic components to your SolidJS apps.",
	"type": "module",
	"module": "dist/index.js",
	"bin": {
		"mystic-ui": "./dist/index.js"
	},
	"files": ["/dist"],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node --minify",
		"version": "bun run ./scripts/bump.ts && git add ./src/version.ts && bun run build",
		"start": "bun --bun run ./src/index.ts",
		"format": "biome format src",
		"lint": "biome lint src",
		"check": "biome check src"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@clack/prompts": "^0.7.0",
		"@types/bun": "latest",
		"commander": "^12.1.0",
		"cosmiconfig": "^9.0.0",
		"magicast": "^0.3.5",
		"nypm": "^0.3.12",
		"ts-deepmerge": "^7.0.1",
		"zod": "^3.23.8"
	},
	"peerDependencies": {
		"typescript": "^5.3.3"
	},
	"publishConfig": {
		"access": "public",
		"tag": "latest"
	},
	"author": {
		"name": "Peter Ryszkiewicz",
		"url": "https://github.com/pRizz"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pRizz/mystic-ui.git"
	},
	"homepage": "https://github.com/pRizz/mystic-ui",
	"bugs": {
		"url": "https://github.com/pRizz/mystic-ui/issues"
	}
}
